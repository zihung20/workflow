{
  "name": "flowyd",
  "version": "0.1.1",
  "description": "A TypeScript library for defining, executing, and visualizing logic workflows",
  "homepage": "https://zihung20.github.io/flowyd/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zihung20/flowyd.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./visualization": {
      "types": "./dist/visualization/index.d.ts",
      "import": "./dist/visualization/index.js",
      "require": "./dist/visualization/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:perf": "vitest run --project perf --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "docs:dev": "vitepress dev docs --port 6060",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 6060"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "zod": "^3.23.8",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.8.3",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2",
    "vitepress": "^1.6.4",
    "vitest": "^1.6.0"
  }
}
